# Football data provider API key (e.g. api-football.com)
FOOTBALL_API_KEY=your_football_api_key_here

# Kalshi prediction market credentials
KALSHI_KEY_ID=your_kalshi_key_id
KALSHI_PRIVATE_KEY=your_kalshi_private_key

# Optional: weather provider for venue enrichment
WEATHER_API_KEY=your_weather_api_key

# Optional: news provider
NEWS_API_KEY=your_news_api_key

# Cache settings
CACHE_TTL_SECONDS=120
